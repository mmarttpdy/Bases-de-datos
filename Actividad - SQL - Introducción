-- Parte C — Consultas (DQL)
-- Q1. Lista todos los clientes ordenados por nombre (ascendente).
-- Resultado esperado: 3 filas ordenadas por nombre

SELECT * FROM Cliente ORDER BY nombre ASC;

-- Q2. Muestra cada reserva con: id_reserva, nombre del cliente, fecha_inicio, fecha_fin, estatus.
-- Resultado esperado: 3 filas con los datos solicitados

SELECT 
  r.id_reserva,
  c.nombre,
  r.fecha_inicio,
  r.fecha_fin,
  r.estatus
FROM Reserva r
JOIN Cliente c ON r.id_cliente = c.id_cliente;

-- Q3. Muestra por reserva: id_reserva, cuántos autos tiene (conteo).
-- Resultado esperado: 3 filas con el id_reserva y el conteo de autos

SELECT 
  r.id_reserva,
  COUNT(ra.id_auto) AS num_autos
FROM Reserva r
LEFT JOIN ReservaAuto ra ON r.id_reserva = ra.id_reserva
GROUP BY r.id_reserva;

-- Q4. Muestra el costo total por reserva, considerando días * (suma de precios por día).
-- Resultado esperado: 3 filas con el id_reserva y el costo total

SELECT
  r.id_reserva,
  SUM(ra.precio_dia * (DATEDIFF(r.fecha_fin, r.fecha_inicio) + 1)) AS costo_total
FROM Reserva r
JOIN ReservaAuto ra ON r.id_reserva = ra.id_reserva
GROUP BY r.id_reserva;

-- Q5. Muestra las reservas ACTIVAS solamente.
-- Resultado esperado: 2 filas con reservas activas

SELECT * FROM Reserva WHERE estatus = 'ACTIVA';

